<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback configuration for the Planner backend.

    - Non-prod profiles: pull in Spring Boot's standard console configuration
      (human-readable colorized pattern) via base.xml.
    - prod profile: emit one JSON object per log line via logstash-logback-encoder
      so deployed logs are queryable by field in aggregators (Loki, CloudWatch, etc.).

    Distributed tracing hook: when tracing lands (e.g. Micrometer Tracing / OTel),
    add a <provider class="...MdcJsonProvider"/> or include trace/span IDs in the
    pattern below. Today MDC is already serialized, so propagating IDs via MDC will
    surface them automatically without an XML change.
-->
<configuration>

    <springProfile name="!prod">
        <!-- Spring Boot defaults: CONSOLE appender with the standard colorized pattern. -->
        <include resource="org/springframework/boot/logging/logback/base.xml"/>
    </springProfile>

    <springProfile name="prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>@timestamp</fieldName>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <version>
                        <fieldName>@version</fieldName>
                    </version>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger_name</fieldName>
                    </loggerName>
                    <threadName>
                        <fieldName>thread_name</fieldName>
                    </threadName>
                    <message>
                        <fieldName>message</fieldName>
                    </message>
                    <stackTrace>
                        <fieldName>stack_trace</fieldName>
                    </stackTrace>
                    <mdc/>
                    <!-- Distributed tracing: trace_id / span_id will appear here automatically
                         once they are populated into MDC by a tracing library. -->
                </providers>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

</configuration>
