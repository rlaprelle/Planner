# Frontend build-time environment variables.
#
# Vite inlines anything prefixed with VITE_ at build time. To use these
# locally, copy this file to .env.local (gitignored) and fill in values.
# CI sets them via the workflow env block (.github/workflows/deploy.yml).

# Origin of the backend API. Leave empty in dev — Vite proxies /api to
# localhost:8080 (see vite.config.js). Set in production builds to point
# the SPA at the cross-origin backend, e.g.:
#
#   VITE_API_URL=https://api.echelplanner.com
#
# The value is prepended to every /api/v1/... path the frontend issues.
VITE_API_URL=
